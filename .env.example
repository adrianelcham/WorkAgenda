# Copy this file to ".env" and fill in your key. Never commit ".env".
# Used only by the server route (api/chat.js) and the Vite dev middleware —
# this key is never exposed to the browser.

ANTHROPIC_API_KEY=your_key_here

# Optional: override the model (defaults to claude-sonnet-4-6).
# ANTHROPIC_MODEL=claude-sonnet-4-6
